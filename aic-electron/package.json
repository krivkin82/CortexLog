    "electron": "^31.0.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.aic.mvp",
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "../aic-backend/dist/aic-backend.exe",
        "to": "backend/aic-backend.exe"
      }
    ]
  }
